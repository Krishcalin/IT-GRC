# ── Database ──────────────────────────────────────────────
POSTGRES_USER=grc
POSTGRES_PASSWORD=changeme
POSTGRES_DB=itgrc
DATABASE_URL=postgresql+asyncpg://grc:changeme@db:5432/itgrc

# ── Backend ───────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-64-char-string
ACCESS_TOKEN_EXPIRE_MINUTES=480
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── First superuser (created on first startup) ───────────
FIRST_SUPERUSER_EMAIL=admin@company.com
FIRST_SUPERUSER_PASSWORD=Admin@123

# ── SAML / OIDC (optional — leave blank for local auth) ──
SAML_METADATA_URL=
OIDC_DISCOVERY_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
